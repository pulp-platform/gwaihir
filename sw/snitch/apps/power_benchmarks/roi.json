<%
    experiments = [
        {"idx":  3, "label": "dma_load"},
        {"idx":  7, "label": "dma_store"},
        {"idx": 11, "label": "crossing"},
        {"idx": 15, "label": "remote_write"},
        {"idx": 22, "label": "gemm"},
        {"idx": 27, "label": "sw_sum"},
        {"idx": 31, "label": "hw_reduction"},
        {"idx": 35, "label": "idle"},
    ]
    active_clusters = [0, 4]
%>

[
% for c in active_clusters:
    // Cluster ${c} — compute cores
    % for j in range(0, 8):
    {
        "thread": "${f'hart_{c * 9 + j + 1}'}",
        "roi": [
            % for exp in experiments:
            {"idx": ${exp['idx']}, "label": "${exp['label']}"},
            % endfor
        ]
    },
    % endfor

    // Cluster ${c} — DM core
    {
        "thread": "${f'hart_{c * 9 + 9}'}",
        "roi": [
            % for exp in experiments:
            {"idx": ${exp['idx']}, "label": "${exp['label']}"},
            % endfor
        ]
    },
% endfor
]
